# ---- App / API ----
APP_URL="http://localhost:3000"
API_PORT="4000"
VITE_API_URL="http://localhost:4000"
NODE_ENV="development"
CORS_ORIGINS="http://localhost:3000"

# ---- Supabase ----
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_DB_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# ---- Stripe ----
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional mapped prices (never keep placeholder values like price_...)
STRIPE_PRICE_CORE=""
STRIPE_PRICE_END=""
STRIPE_PRICE_START=""
STRIPE_PRICE_FLOW=""
STRIPE_PRICE_COMBO=""

# ---- Internal automation outbox ----
AUTOMATION_WEBHOOK_BASE_URL="http://localhost:4000/internal/hooks"
AUTOMATION_INTERNAL_TOKEN="<strong-random-token>"

# ---- Rate limits ----
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_CONTACT_MAX="20"
RATE_LIMIT_CHECKOUT_MAX="30"
RATE_LIMIT_AUTOMATION_MAX="10"
RATE_LIMIT_WEBHOOK_MAX="180"
